# Personal AI Employee - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# Development mode - prevents real external actions
DEV_MODE=true

# Dry run mode - logs actions without executing
DRY_RUN=true

# Vault path (absolute path recommended)
VAULT_PATH=C:/Personal_Ai_Employee_FTEs/vault

# =============================================================================
# WATCHER CONFIGURATION
# =============================================================================

# File System Watcher
DROP_FOLDER_PATH=C:/Personal_Ai_Employee_FTEs/drop_folder
FILESYSTEM_WATCHER_INTERVAL=30

# Gmail Watcher (Silver Tier)
# GMAIL_CLIENT_ID=your_client_id_here
# GMAIL_CLIENT_SECRET=your_client_secret_here
# GMAIL_CREDENTIALS_PATH=path/to/credentials.json
# GMAIL_TOKEN_PATH=path/to/token.json
# GMAIL_WATCHER_INTERVAL=120

# WhatsApp Watcher (Silver Tier)
# WHATSAPP_SESSION_PATH=/secure/path/to/whatsapp_session
# WHATSAPP_WATCHER_INTERVAL=30

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# Email MCP (Silver Tier)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# =============================================================================
# LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# SECURITY
# =============================================================================

# Secret key for signing tokens (generate a secure random string)
SECRET_KEY=change_this_to_a_secure_random_string

# Encryption key for vault (optional, for encrypted vaults)
# VAULT_ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# BUSINESS CONFIGURATION
# =============================================================================

# Business name for AI Employee
BUSINESS_NAME=My Business

# Default currency
DEFAULT_CURRENCY=USD

# Payment approval threshold
PAYMENT_APPROVAL_THRESHOLD=100

# =============================================================================
# ODoo CONFIGURATION (Gold Tier)
# =============================================================================

# ODOO_URL=http://localhost:8069
# ODOO_DB_NAME=odoo_db
# ODOO_USERNAME=admin
# ODOO_PASSWORD=admin
